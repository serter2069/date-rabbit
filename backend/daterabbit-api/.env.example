# Server
PORT=3004
NODE_ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=daterabbit
DB_PASSWORD=daterabbit
DB_NAME=daterabbit

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRATION=7d
DEV_AUTH=true  # Set to false in production — disables OTP bypass

# Email (Brevo/SMTP)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@daterabbit.com

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=60  # requests per minute

# Stripe (Payments)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Checkr (Background checks)
CHECKR_WEBHOOK_SECRET=  # HMAC secret from Checkr dashboard -> Webhooks

# App URLs
APP_URL=https://daterabbit.smartlaunchhub.com

# MinIO S3 Storage
HETZNER_S3_ENDPOINT=https://s3.smartlaunchhub.com
HETZNER_S3_BUCKET=daterabbit
HETZNER_S3_ACCESS_KEY=<project-user>
HETZNER_S3_SECRET_KEY=<secret>

# Valkey / Redis (BullMQ queues)
REDIS_URL=redis://localhost:6379
